{
	"name": "@pajecawav/tools",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"license": "MIT",
	"exports": {
		".": "./dist/index.mjs",
		"./cli": "./dist/cli/index.mjs",
		"./package.json": "./package.json"
	},
	"bin": {
		"pt": "./dist/cli/index.mjs"
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"dev:cli": "tsx --tsconfig tsconfig.lib.json ./src/cli/index.ts",
		"cli": "node ./dist/cli/index.mjs",
		"lint": "run-p -l lint:*",
		"lint:oxlint": "oxlint .",
		"lint:tsc": "tsc -b --noEmit",
		"lint:format": "oxfmt --check",
		"lint:package": "publint",
		"format": "oxfmt . --write",
		"prepare": "husky",
		"prepublishOnly": "npm-run-all -p -l lint:* -s build"
	},
	"peerDependencies": {
		"oxfmt": "^0.47.0",
		"oxlint": "^1.63.0",
		"prettier": "^3.8.3"
	},
	"peerDependenciesMeta": {
		"oxfmt": {
			"optional": true
		},
		"oxlint": {
			"optional": true
		},
		"prettier": {
			"optional": true
		}
	},
	"dependencies": {
		"@commitlint/config-conventional": "^20.5.3",
		"@commitlint/types": "^20.5.0",
		"@pajecawav/prettier-config": "^1.0.2",
		"c12": "4.0.0-beta.4",
		"citty": "^0.2.2",
		"consola": "^3.4.2",
		"defu": "^6.1.7",
		"execa": "^9.6.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"cross-env": "^10.1.0",
		"npm-run-all2": "^8.0.4",
		"oxfmt": "^0.47.0",
		"oxlint": "^1.63.0",
		"oxlint-tsgolint": "^0.22.1",
		"publint": "^0.3.18",
		"tsdown": "^0.21.10",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	},
	"packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
