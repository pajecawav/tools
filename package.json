{
	"name": "@pajecawav/tools",
	"version": "0.0.6",
	"type": "module",
	"license": "MIT",
	"exports": {
		".": "./dist/index.mjs",
		"./cli": "./dist/cli/index.mjs",
		"./package.json": "./package.json"
	},
	"bin": {
		"pt": "./dist/cli/index.mjs"
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"dev:cli": "tsx --tsconfig tsconfig.lib.json ./src/cli/index.ts",
		"cli": "node ./dist/cli/index.mjs",
		"lint": "cross-env FORCE_COLOR=1 run-p -l lint:*",
		"lint:oxlint": "oxlint .",
		"lint:tsc": "tsc -b --noEmit",
		"lint:format": "oxfmt --check",
		"lint:package": "publint",
		"format": "oxfmt . --write",
		"prepare": "husky",
		"prepublishOnly": "npm-run-all -p -l lint:* -s build"
	},
	"peerDependencies": {
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"prettier": "^3.9.4"
	},
	"peerDependenciesMeta": {
		"oxfmt": {
			"optional": true
		},
		"oxlint": {
			"optional": true
		},
		"prettier": {
			"optional": true
		}
	},
	"dependencies": {
		"@commitlint/config-conventional": "^21.2.0",
		"@commitlint/types": "^21.2.0",
		"@pajecawav/prettier-config": "^1.0.2",
		"c12": "4.0.0-beta.5",
		"citty": "^0.2.2",
		"consola": "^3.4.2",
		"defu": "^6.1.7",
		"execa": "^10.0.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8"
	},
	"devDependencies": {
		"@types/node": "^24.13.3",
		"cross-env": "^10.1.0",
		"npm-run-all2": "^9.0.2",
		"oxfmt": "^0.59.0",
		"oxlint": "^1.74.0",
		"oxlint-tsgolint": "^0.25.0",
		"publint": "^0.3.21",
		"tsdown": "^0.22.9",
		"tsx": "^4.23.1",
		"typescript": "^7.0.2"
	},
	"packageManager": "pnpm@11.14.0+sha512.66c1ac4c7d4762d6d7dde44c7f3e5a73591ed0a0806e751d4ed32d4f004f25b2285a906b1fd8a9e3e621df3b4e2858bf88e50e0cf626bedbe977fe434a5caf85"
}
