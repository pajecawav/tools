{
	"name": "@pajecawav/tools",
	"version": "0.0.5",
	"type": "module",
	"license": "MIT",
	"exports": {
		".": "./dist/index.mjs",
		"./cli": "./dist/cli/index.mjs",
		"./package.json": "./package.json"
	},
	"bin": {
		"pt": "./dist/cli/index.mjs"
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"dev:cli": "tsx --tsconfig tsconfig.lib.json ./src/cli/index.ts",
		"cli": "node ./dist/cli/index.mjs",
		"lint": "cross-env FORCE_COLOR=1 run-p -l lint:*",
		"lint:oxlint": "oxlint .",
		"lint:tsc": "tsgo -b --noEmit",
		"lint:format": "oxfmt --check",
		"lint:package": "publint",
		"format": "oxfmt . --write",
		"prepare": "husky",
		"prepublishOnly": "npm-run-all -p -l lint:* -s build"
	},
	"peerDependencies": {
		"oxfmt": "~0.54.0",
		"oxlint": "^1.69.0",
		"prettier": "^3.8.4"
	},
	"peerDependenciesMeta": {
		"oxfmt": {
			"optional": true
		},
		"oxlint": {
			"optional": true
		},
		"prettier": {
			"optional": true
		}
	},
	"dependencies": {
		"@commitlint/config-conventional": "^21.0.2",
		"@commitlint/types": "^21.0.1",
		"@pajecawav/prettier-config": "^1.0.2",
		"c12": "4.0.0-beta.5",
		"citty": "^0.2.2",
		"consola": "^3.4.2",
		"defu": "^6.1.7",
		"execa": "^9.6.1",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7"
	},
	"devDependencies": {
		"@types/node": "^25.9.3",
		"@typescript/native-preview": "7.0.0-dev.20260611.2",
		"cross-env": "^10.1.0",
		"npm-run-all2": "^9.0.1",
		"oxfmt": "~0.54.0",
		"oxlint": "^1.69.0",
		"oxlint-tsgolint": "^0.23.0",
		"publint": "^0.3.21",
		"tsdown": "^0.22.2",
		"tsx": "^4.22.4"
	},
	"packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed"
}
