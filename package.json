{
	"name": "@pajecawav/tools",
	"version": "0.0.4",
	"type": "module",
	"license": "MIT",
	"exports": {
		".": "./dist/index.mjs",
		"./cli": "./dist/cli/index.mjs",
		"./package.json": "./package.json"
	},
	"bin": {
		"pt": "./dist/cli/index.mjs"
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"dev:cli": "tsx --tsconfig tsconfig.lib.json ./src/cli/index.ts",
		"cli": "node ./dist/cli/index.mjs",
		"lint": "cross-env FORCE_COLOR=1 run-p -l lint:*",
		"lint:oxlint": "oxlint .",
		"lint:tsc": "tsgo -b --noEmit",
		"lint:format": "oxfmt --check",
		"lint:package": "publint",
		"format": "oxfmt . --write",
		"prepare": "husky",
		"prepublishOnly": "npm-run-all -p -l lint:* -s build"
	},
	"peerDependencies": {
		"oxfmt": "~0.47.0",
		"oxlint": "^1.63.0",
		"prettier": "^3.8.3"
	},
	"peerDependenciesMeta": {
		"oxfmt": {
			"optional": true
		},
		"oxlint": {
			"optional": true
		},
		"prettier": {
			"optional": true
		}
	},
	"dependencies": {
		"@commitlint/config-conventional": "^21.0.2",
		"@commitlint/types": "^21.0.1",
		"@pajecawav/prettier-config": "^1.0.2",
		"c12": "4.0.0-beta.5",
		"citty": "^0.2.2",
		"consola": "^3.4.2",
		"defu": "^6.1.7",
		"execa": "^9.6.1",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.5"
	},
	"devDependencies": {
		"@types/node": "^25.9.1",
		"@typescript/native-preview": "7.0.0-dev.20260527.2",
		"cross-env": "^10.1.0",
		"npm-run-all2": "^9.0.1",
		"oxfmt": "~0.52.0",
		"oxlint": "^1.67.0",
		"oxlint-tsgolint": "^0.23.0",
		"publint": "^0.3.21",
		"tsdown": "^0.22.1",
		"tsx": "^4.22.3"
	},
	"packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
}
