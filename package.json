{
	"name": "@pajecawav/tools",
	"version": "0.0.3",
	"type": "module",
	"license": "MIT",
	"exports": {
		".": "./dist/index.mjs",
		"./cli": "./dist/cli/index.mjs",
		"./package.json": "./package.json"
	},
	"bin": {
		"pt": "./dist/cli/index.mjs"
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"dev:cli": "tsx --tsconfig tsconfig.lib.json ./src/cli/index.ts",
		"cli": "node ./dist/cli/index.mjs",
		"lint": "cross-env FORCE_COLOR=1 run-p -l lint:*",
		"lint:oxlint": "oxlint .",
		"lint:tsc": "tsgo -b --noEmit",
		"lint:format": "oxfmt --check",
		"lint:package": "publint",
		"format": "oxfmt . --write",
		"prepare": "husky",
		"prepublishOnly": "npm-run-all -p -l lint:* -s build"
	},
	"peerDependencies": {
		"oxfmt": "~0.47.0",
		"oxlint": "^1.63.0",
		"prettier": "^3.8.3"
	},
	"peerDependenciesMeta": {
		"oxfmt": {
			"optional": true
		},
		"oxlint": {
			"optional": true
		},
		"prettier": {
			"optional": true
		}
	},
	"dependencies": {
		"@commitlint/config-conventional": "^21.0.1",
		"@commitlint/types": "^21.0.1",
		"@pajecawav/prettier-config": "^1.0.2",
		"c12": "4.0.0-beta.5",
		"citty": "^0.2.2",
		"consola": "^3.4.2",
		"defu": "^6.1.7",
		"execa": "^9.6.1",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.4"
	},
	"devDependencies": {
		"@types/node": "^25.8.0",
		"@typescript/native-preview": "7.0.0-dev.20260515.1",
		"cross-env": "^10.1.0",
		"npm-run-all2": "^8.0.4",
		"oxfmt": "~0.49.0",
		"oxlint": "^1.64.0",
		"oxlint-tsgolint": "^0.22.1",
		"publint": "^0.3.21",
		"tsdown": "^0.22.0",
		"tsx": "^4.22.0"
	},
	"packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
